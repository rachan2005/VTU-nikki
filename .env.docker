# ============================================================================
# VTU Diary Automation v3.0 — Docker Environment Configuration
# ============================================================================
# This file contains the environment variables used when running through Docker.
# Docker-specific overrides are applied here.

# ============================================================================
# LLM PROVIDER
# ============================================================================
LLM_PROVIDER=auto

# (Keys should be set by individual users in the Settings UI for security)
# GROQ_API_KEY=
# GEMINI_API_KEY=
# CEREBRAS_API_KEY=
# OPENAI_API_KEY=

# ============================================================================
# BROWSER AUTOMATION
# ============================================================================
HEADLESS=true
MAX_PARALLEL_BROWSERS=2
SUBMISSION_DELAY_SECONDS=3.0

# ============================================================================
# WEB SERVER (DOCKER)
# ============================================================================
# 0.0.0.0 is mandatory for Docker containers to be reachable
API_HOST=0.0.0.0
API_PORT=5000
DEBUG_MODE=false

# ============================================================================
# DATABASE (DOCKER)
# ============================================================================
# Ensure database is in the volumed data directory for persistence
DATABASE_URL=sqlite:///data/vtu_automation.db

# ============================================================================
# APP CONFIG
# ============================================================================
SKIP_WEEKENDS=true
SKIP_HOLIDAYS=true
DEFAULT_COUNTRY=IN
MAX_DATE_RANGE_DAYS=90
LOG_LEVEL=INFO
ENABLE_SCREENSHOTS=true
ENABLE_CACHING=true
